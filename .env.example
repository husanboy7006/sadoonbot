# OpenAI API Key (platform.openai.com dan) — SMM Studio uchun
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Key (console.groq.com dan) — Tilmoch AI uchun (asosiy)
GROQ_KEY=your_groq_api_key_here

# Replicate API Key (replicate.com dan) — CGI Artist uchun
REPLICATE_KEY=your_replicate_api_key_here

# Sadoon API Key (ixtiyoriy, API endpoint uchun)
SADOON_API_KEY=your_sadoon_api_key_here

# Webhook Base URL (Hugging Face yoki boshqa hosting uchun)
BASE_URL=https://your-domain.com

