# Telegram Bot Token (BotFather'dan olingan)
BOT_TOKEN=your_telegram_bot_token_here

# Admin Telegram ID (sizning ID'ingiz)
ADMIN_ID=your_telegram_user_id_here

# Supabase Database (supabase.com'dan)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# OpenAI API Key (platform.openai.com dan) — SMM Studio uchun
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Key (console.groq.com dan) — Tilmoch AI uchun (asosiy)
GROQ_KEY=your_groq_api_key_here

# Gemini API Key (Google AI Studio'dan) — Tilmoch AI fallback
GEMINI_KEY=your_gemini_api_key_here

# To'lov admin username — premium tasdiqlash uchun
PAYMENT_ADMIN=@your_admin_username

# Webhook Base URL (Railway yoki boshqa hosting uchun)
BASE_URL=https://your-domain.up.railway.app

# Sadoon API Key (ixtiyoriy, API endpoint himoyasi uchun)
SADOON_API_KEY=your_secret_key_here

# SMM sozlamalari
FREE_DAILY_LIMIT=3
MAX_TOKENS=5000
TEMPERATURE=0.8